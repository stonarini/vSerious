  <!-- x86 and x64 configurations target Windows 7 explicitly, link the
       Win7-compatible BufferOverflowK.lib instead of BufferOverflowFastFailK.lib
       (which uses Win 8+ int 0x29 fast-fail that doesn't exist on Win 7),
       and use Desktop driver target instead of Universal (Universal
       requires Win 10 runtime helpers).
       Per https://learn.microsoft.com/.../building-drivers-for-different-versions-of-windows
       the KernelBufferOverflowLib element must appear before the
       Microsoft.Cpp.props import - this PropertyGroup with Label="Configuration"
       satisfies that requirement. -->
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|Win32'" Label="Configuration">
    <TargetVersion>Windows7</TargetVersion>
    <UseDebugLibraries>true</UseDebugLibraries>
    <PlatformToolset>WindowsKernelModeDriver10.0</PlatformToolset>
    <ConfigurationType>Driver</ConfigurationType>
    <DriverType>KMDF</DriverType>
    <DriverTargetPlatform>Desktop</DriverTargetPlatform>
    <KernelBufferOverflowLib>$(DDK_LIB_PATH)\BufferOverflowK.lib</KernelBufferOverflowLib>
    <KMDF_VERSION_MAJOR>1</KMDF_VERSION_MAJOR>
    <KMDF_VERSION_MINOR>11</KMDF_VERSION_MINOR>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|Win32'" Label="Configuration">
    <TargetVersion>Windows7</TargetVersion>
    <UseDebugLibraries>false</UseDebugLibraries>
    <PlatformToolset>WindowsKernelModeDriver10.0</PlatformToolset>
